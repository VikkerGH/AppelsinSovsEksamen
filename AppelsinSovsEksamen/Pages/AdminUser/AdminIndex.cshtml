@page
@model AppelsinSovsEksamen.Pages.AdminUser.AdminIndexModel
@{
    ViewData["Title"] = "Admin Panel";
}

<div class="py-3 px-4 mb-4 rounded-3 d-flex align-items-center gap-3"
     style="background-color: #1a1a1a;">
    <div class="rounded-circle d-flex align-items-center justify-content-center"
         style="width:48px; height:48px; background:#ff8c00; flex-shrink:0;">
        <i class="bi bi-gear-fill" style="color:#1a1a1a; font-size:1.25rem;"></i>
    </div>
    <div>
        <h1 class="mb-0 fw-bold" style="color:#ff8c00; font-size:1.5rem;">Admin panel</h1>
        <p class="mb-0" style="color:#aaa; font-size:0.875rem;">
            Velkommen tilbage, @HttpContext.Session.GetString("UserName")
        </p>
    </div>
    <div class="ms-auto">
        <span class="badge rounded-pill px-3 py-2"
              style="background:#2a2a2a; color:#ff8c00; border:1px solid #ff8c00;">
            Administrator
        </span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="p-3 rounded-2" style="background-color:#2a2a2a;">
            <div class="text-muted mb-1" style="font-size:0.75rem;">Brugere</div>
            <div class="fw-bold" style="font-size:1.5rem; color:#f0f0f0;">@Model.UserCount</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="p-3 rounded-2" style="background-color:#2a2a2a;">
            <div class="text-muted mb-1" style="font-size:0.75rem;">Produkter</div>
            <div class="fw-bold" style="font-size:1.5rem; color:#f0f0f0;">@Model.ProductCount</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="p-3 rounded-2" style="background-color:#2a2a2a;">
            <div class="text-muted mb-1" style="font-size:0.75rem;">Anmeldelser</div>
            <div class="fw-bold" style="font-size:1.5rem; color:#f0f0f0;">@Model.AnmeldelseCount</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="background-color:#2a2a2a; color:#f0f0f0;">
            <div class="card-body d-flex flex-column gap-2">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px; height:36px; background:#fff3e0;">
                    <i class="bi bi-people-fill" style="color:#e65100;"></i>
                </div>
                <h5 class="fw-bold mb-0" style="color:#ff8c00;">Administrer brugere</h5>
                <p class="mb-0" style="color:#aaa; font-size:0.875rem;">Se og slet brugere på platformen.</p>
                <a asp-page="/AdminUser/UserIndex"
                   class="btn mt-auto fw-bold"
                   style="background-color:#ff8c00; color:#1a1a1a;">
                    Gå til brugere →
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="background-color:#2a2a2a; color:#f0f0f0;">
            <div class="card-body d-flex flex-column gap-2">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px; height:36px; background:#e8f5e9;">
                    <i class="bi bi-bag-fill" style="color:#2e7d32;"></i>
                </div>
                <h5 class="fw-bold mb-0" style="color:#ff8c00;">Merch / Produkter</h5>
                <p class="mb-0" style="color:#aaa; font-size:0.875rem;">Opret, rediger og slet produkter i shoppen.</p>
                <a asp-page="/AdminProduct/ProductIndex"
                   class="btn mt-auto fw-bold"
                   style="background-color:#ff8c00; color:#1a1a1a;">
                    Gå til merch →
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="background-color:#2a2a2a; color:#f0f0f0;">
            <div class="card-body d-flex flex-column gap-2">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px; height:36px; background:#f3e5f5;">
                    <i class="bi bi-star-fill" style="color:#6a1b9a;"></i>
                </div>
                <h5 class="fw-bold mb-0" style="color:#ff8c00;">Administrer anmeldelser</h5>
                <p class="mb-0" style="color:#aaa; font-size:0.875rem;">Se og slet anmeldelser fra brugere.</p>
                <a asp-page="/AdminAnmeldelse/AnmeldelseIndex"
                   class="btn mt-auto fw-bold"
                   style="background-color:#ff8c00; color:#1a1a1a;">
                    Gå til anmeldelser →
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="background-color:#2a2a2a; color:#f0f0f0;">
            <div class="card-body d-flex flex-column gap-2">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px; height:36px; background:#e3f2fd;">
                    <i class="bi bi-person-fill-add" style="color:#1565c0;"></i>
                </div>
                <h5 class="fw-bold mb-0" style="color:#ff8c00;">Opret admin bruger</h5>
                <p class="mb-0" style="color:#aaa; font-size:0.875rem;">Opret en ny bruger med admin rettigheder.</p>
                <a asp-page="/AdminUser/CreateAdmin"
                   class="btn mt-auto fw-bold"
                   style="background-color:#ff8c00; color:#1a1a1a;">
                    Opret admin →
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="background-color:#2a2a2a; color:#f0f0f0;">
            <div class="card-body d-flex flex-column gap-2">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:36px; height:36px; background:#fce4ec;">
                    <i class="bi bi-controller" style="color:#c2185b;"></i>
                </div>
                <h5 class="fw-bold mb-0" style="color:#ff8c00;">Administrer spil</h5>
                <p class="mb-0" style="color:#aaa; font-size:0.875rem;">Opret, rediger og slet spil på platformen.</p>
                <a asp-page="/AdminGame/GameIndex"
                   class="btn mt-auto fw-bold"
                   style="background-color:#ff8c00; color:#1a1a1a;">
                    Gå til spil →
                </a>
            </div>
        </div>
    </div>
</div>


