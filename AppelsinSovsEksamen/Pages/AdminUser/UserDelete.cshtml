@page "{id:guid}"
@model AppelsinSovsEksamen.Pages.AdminUser.UserDeleteModel
@{
    ViewData["Title"] = "Slet bruger";
}

<style>
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        background: #ffffff;
        color: #000000;
        padding: 25px;
        border-radius: 10px;
        width: 450px;
        box-shadow: 0 0 20px rgba(0,0,0,0.3);
        animation: fadeIn 0.2s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

@if (Model.UserToDelete is null)
{
    <div class="alert alert-danger">Brugeren blev ikke fundet.</div>
}
else
{
    <div class="overlay">
        <div class="modal-box">

            <h3 class="text-danger fw-bold mb-3">Bekræft sletning</h3>

            <p>Du er ved at slette følgende bruger og al tilhørende data:</p>

            <dl class="row">
                <dt class="col-sm-4">Navn</dt>
                <dd class="col-sm-8">@Model.UserToDelete.Name</dd>

                <dt class="col-sm-4">Oprettet</dt>
                <dd class="col-sm-8">@Model.UserToDelete.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</dd>
            </dl>

            <div class="d-flex gap-2 mt-4">
                <form method="post">
                    <button type="submit" class="btn btn-danger">Bekræft sletning</button>
                </form>

                <a asp-page="UserIndex" class="btn btn-secondary">Annuller</a>
            </div>

        </div>
    </div>
}
