@page
@model AppelsinSovsEksamen.Pages.AdminUser.UserIndexModel
@{
    ViewData["Title"] = "Administrer brugere";
}

<h1 class="mb-4">Brugerliste</h1>

@if (!Model.Users.Any())
{
    <div class="alert alert-info">Ingen brugere fundet.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Navn</th>
                <th>Email</th>
                <th>Oprettet</th>
                <th>Handlinger</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</td>
                    <td>
                        <a asp-page="UserDelete"
                           asp-route-id="@user.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Er du sikker på, at du vil slette brugeren \'@user.Name\'? Dette kan ikke fortrydes.');">
                            Slet
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
