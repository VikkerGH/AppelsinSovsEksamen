@page
@model AppelsinSovsEksamen.Pages.User.UserEditModel
@{
    ViewData["Title"] = "Min profil";


}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        @if (Model.CurrentUser is not null)
        {
            <div class="card border-0 shadow" style="background-color: #2a2a2a; color: #f0f0f0;">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-4" style="color: #ff8c00;">Min profil</h2>
                    <dl class="row mb-4">
                        <dt class="col-sm-4" style="color: #aaa;">Brugernavn</dt>
                        <dd class="col-sm-8">@Model.CurrentUser.Name</dd>
                        <dt class="col-sm-4" style="color: #aaa;">Oprettet</dt>
                        <dd class="col-sm-8">@Model.CurrentUser.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</dd>
                    </dl>
                    <hr style="border-color: #444;" />
                    <a asp-page="/UserSides/UserDelete"   
                       asp-route-id="@Model.CurrentUser.Id"
                       class="btn w-100 fw-bold mt-3"
                       style="background-color: #cc0000; color: white;">
                        Slet min konto
                    </a>

                   
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                Du er ikke logget ind. <a href="/UserSides/UserLogIn" style="color: #ff8c00;">Log ind her</a>
            </div>
        }
    </div>
</div>