<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppelsinSovsEksamen</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppelsinSovsEksamen.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #1a1a1a;">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index" style="color: #ff8c00;">AppelsinSovs</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/Index">Forside</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/HighScore/Index">Highscore</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/AdminUser/UserIndex">Administrer brugere</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/AdminProduct/ProductIndex">Admin-Merch</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/UserProduct/Index">Merch</a>
                        </li>
                        @if (Context.Session.GetString("UserId") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/UserSides/UserLogIn">Log ind</a>
                            </li>
                        }
                        </ul>
                        @if (Context.Session.GetString("UserId") != null)
                        {
                        <div class="ms-auto d-flex align-items-center">
                            <span class="nav-link" style="color: #ff8c00;">
                                @Context.Session.GetString("UserName")
                            </span>

                            <a asp-page="/UserSides/UserProfile" class="ms-3" style="text-decoration:none;">
                                <div style="width:38px; height:38px; border-radius:50%;
                            background:linear-gradient(135deg,#ff8c00,#e67e22);
                            display:flex; align-items:center; justify-content:center;
                            font-size:1.2rem; font-weight:900; color:#fff;
                            border:2px solid rgba(255,179,71,0.5);
                            box-shadow:0 0 10px rgba(255,140,0,0.3);">
                                    @Context.Session.GetString("UserName")!.Substring(0, 1).ToUpper()
                                </div>
                            </a>
                        </div>
                        }
                    </div>
                </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer" style="background-color: #1a1a1a; color: #aaa;">
        <div class="container">
            &copy; 2026 - AppelsinSovs - <a asp-area="" asp-page="/Privacy" style="color: #ff8c00;">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
