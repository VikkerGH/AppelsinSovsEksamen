<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppelsinSovsEksamen</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppelsinSovsEksamen.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @if (Context.Session.GetString("IsAdmin") == "true")
        {
            <nav class="navbar navbar-dark border-bottom mb-3" style="background-color: #1a1a1a;">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-page="/AdminUser/AdminIndex" style="color: #ff8c00;">
                        <i class="bi bi-gear-fill me-1"></i> Admin Panel
                    </a>
                    <div class="d-flex align-items-center gap-3">
                        <span style="color: #aaa; font-size: 0.875rem;">
                           <strong style="color: #ff8c00;">@Context.Session.GetString("UserName")</strong>
                        </span>
                        <a asp-page="/UserSides/UserLogUd" class="btn btn-sm fw-bold"
                           style="background-color: #ff8c00; color: #1a1a1a;">
                            Log ud
                        </a>
                    </div>
                </div>
            </nav>
        }
        else
        {
            <nav class="navbar navbar-expand-sm navbar-dark border-bottom mb-3" style="background-color: #1a1a1a;">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index" style="color: #ff8c00;">AppelsinSovs</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Index">Forside</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-page="/HighScore/Index">Highscore</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-page="/Privacy">Privacy</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-page="/UserProduct/Index">Merch</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            @if (Context.Session.GetString("UserId") != null)
                            {
                                <li class="nav-item d-flex align-items-center gap-2">
                                    <a asp-page="/UserSides/UserEdit" class="d-flex align-items-center gap-2 text-decoration-none">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                             style="width:36px; height:36px; background:#ff8c00; color:#1a1a1a; font-size:0.875rem;">
                                            @Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper()
                                        </div>
                                       
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-page="/UserSides/UserLogUd">Log ud</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-page="/UserSides/UserLogIn">Log ind</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        }
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer" style="background-color: #1a1a1a; color: #aaa;">
        <div class="container">
            &copy; 2026 - AppelsinSovs - <a asp-area="" asp-page="/Privacy" style="color: #ff8c00;">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>