@page
@model AppelsinSovsEksamen.Pages.Game.HvorFilanErAppelsinenModel
@{
    ViewData["Title"] = "Hvor filan er Appelsinen";
}

<!-- TILFØJET: Lidt CSS så din popup ser pæn ud og lægger sig over spillet -->
<style>
    .highscore-popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .highscore-popup {
        background: #2a2a2a;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        color: white;
        border: 3px solid #ff8c00;
        min-width: 300px;
    }

    .btn-submit {
        background: #ff8c00;
        color: #1a1a1a;
        padding: 10px 20px;
        border: none;
        font-weight: bold;
        border-radius: 5px;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #e67e00;
        }

    .btn-start {
        background: #444;
        color: white;
        padding: 10px 20px;
        border: none;
        font-weight: bold;
        border-radius: 5px;
        cursor: pointer;
    }

        .btn-start:hover {
            background: #555;
        }
</style>

<link rel="shortcut icon" href="/unitygame/TemplateData/favicon.ico">
<link rel="stylesheet" href="/unitygame/TemplateData/style.css">

<div id="unity-container" class="unity-desktop" style="margin: 0 auto; display: flex; flex-direction: column; align-items: center;">

    <canvas id="unity-canvas" width=960 height=540 tabindex="-1"></canvas>

    <div id="unity-loading-bar">
        <div id="unity-logo"></div>
        <div id="unity-progress-bar-empty">
            <div id="unity-progress-bar-full"></div>
        </div>
    </div>
    <div id="unity-warning"> </div>
    <div id="unity-footer" style="width: 960px;">
        <div id="unity-logo-title-footer"></div>
        <div id="unity-fullscreen-button"></div>
        <div id="unity-build-title">Hvor filan er Appelsinen</div>
    </div>
</div>

<script>
    var canvas = document.querySelector("#unity-canvas");

    function unityShowBanner(msg, type) {
        var warningBanner = document.querySelector("#unity-warning");
        function updateBannerVisibility() {
            warningBanner.style.display = warningBanner.children.length ? 'block' : 'none';
        }
        var div = document.createElement('div');
        div.innerHTML = msg;
        warningBanner.appendChild(div);
        if (type == 'error') div.style = 'background: red; padding: 10px;';
        else {
            if (type == 'warning') div.style = 'background: yellow; padding: 10px;';
            setTimeout(function () {
                warningBanner.removeChild(div);
                updateBannerVisibility();
            }, 5000);
        }
        updateBannerVisibility();
    }

    var buildUrl = "/unitygame/Build";
    var loaderUrl = buildUrl + "/HFEAGame.loader.js";
    var config = {
        arguments: [],
        dataUrl: buildUrl + "/HFEAGame.data",
        frameworkUrl: buildUrl + "/HFEAGame.framework.js",
        codeUrl: buildUrl + "/HFEAGame.wasm",
        streamingAssetsUrl: "/unitygame/StreamingAssets",
        companyName: "DefaultCompany",
        productName: "Hvor filan er Appelsinen",
        productVersion: "1.0",
        showBanner: unityShowBanner,
    };

    if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
        canvas.style.display = "none";
        document.querySelector("#unity-footer").style.display = "none";
        document.querySelector("#unity-loading-bar").style.display = "none";
        var warningDiv = document.createElement("div");
        warningDiv.innerHTML = `
            <div style="text-align: center; padding: 40px; background: #fffde7; border: 3px dashed #d4af37; border-radius: 15px; margin-top: 50px; max-width: 400px; font-family: sans-serif; color: #333;">
                <h2 style="margin-top: 0;"> Hovsa!</h2>
                <p>Spillet <b>'Hvor filan er Appelsinen'</b> kræver en mus og kan desværre kun spilles på PC.</p>
                <p>Åbn hjemmesiden på din computer for at fange appelsinen!</p>
            </div>
        `;
        document.querySelector("#unity-container").appendChild(warningDiv);
    } else {
        canvas.style.width = "960px";
        canvas.style.height = "540px";

        document.querySelector("#unity-loading-bar").style.display = "block";

        var script = document.createElement("script");
        script.src = loaderUrl;
        script.onload = () => {
            createUnityInstance(canvas, config, (progress) => {
                document.querySelector("#unity-progress-bar-full").style.width = 100 * progress + "%";
            }).then((unityInstance) => {
                document.querySelector("#unity-loading-bar").style.display = "none";
                document.querySelector("#unity-fullscreen-button").onclick = () => {
                    unityInstance.SetFullscreen(1);
                };
            }).catch((message) => {
                alert(message);
            });
        };
        document.body.appendChild(script);
    }
</script>

<script>
    console.log("SCRIPTET ER LOADET OG KLAR");

    window.ReceiveScoreFromUnity = function (score) {
        console.log("🚨 BROWSEREN GREB SCOREN FRA UNITY: " + score);

        document.getElementById("final-score-value").innerText = score;
        document.getElementById("score-input").value = score;
        document.getElementById("highscore-popup").style.display = "flex";

        // Fjern fokus fra Unity
        var canvas = document.getElementById("unity-canvas");
        if(canvas) { canvas.blur(); }

        var nameInput = document.getElementById("player-name");
        if (nameInput) { nameInput.focus(); }
    };

    // ATOMBOMBEN: Fanger tasterne FØR Unity gør det, hvis du står i skrivefeltet
    ['keydown', 'keyup', 'keypress'].forEach(function(eventName) {
        window.addEventListener(eventName, function(e) {
            // Tjekker om du aktivt står og klikker inde i navnefeltet
            if (document.activeElement && document.activeElement.id === "player-name") {
                e.stopImmediatePropagation(); // Dræber eventet, så Unity ikke stjæler det!
            }
        }, true); // 'true' betyder at vi aflytter det allertidligst muligt
    });
</script>

@* Game Over Popup til Unity Spillet *@
<div class="highscore-popup-overlay" id="highscore-popup" style="display: none;">
    <div class="highscore-popup">
        <h2 id="popup-title">🏆 Tiden er gået!</h2>
        <p class="final-score">Du scorede: <strong id="final-score-value">0</strong> point</p>

        <form method="post" id="highscore-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Score" id="score-input" value="0" />

            @if (Model.IsLoggedIn)
            {
                <div class="logged-in-info" style="margin-bottom: 15px;">
                    ✅ Gemmes som <strong>@Model.SessionUserName</strong>
                </div>
                <input type="hidden" name="PlayerName" value="@Model.SessionUserName" />
            }
            else
            {
                <div id="guest-name-area" style="margin-bottom: 15px;">
                    <label for="player-name" style="display:block; margin-bottom:5px;">Dit navn til highscore:</label>
                    <input type="text" name="PlayerName" id="player-name"
                           maxlength="20" placeholder="Indtast dit navn..." required
                           style="padding: 5px; border-radius: 5px; border: 1px solid #ccc; color: black; background: white;" />
                </div>
                <p style="font-size:0.85rem; color:#888; margin-top:0.5rem;">
                    <!-- MAGIEN HER: target="_blank" åbner i en ny fane, så spillet ikke nulstiller! -->
                    <a href="/UserSides/UserLogIn" target="_blank" style="color:#ff8c00;">Husk at Log ind</a>
                    for at gemme din fremtidige score på din profil.
                </p>
            }

            <button type="submit" class="btn-submit">💾 Gem Score</button>
        </form>

        <button class="btn-start" id="btn-close-popup" style="margin-top:1rem;" onclick="location.reload();">Prøv igen</button>
    </div>
</div>