@page
@model IndexModel
@{
    ViewData["Title"] = "Forside";
}

<div class="text-center mb-5 py-5 rounded-3" style="background-color: #1a1a1a;">
    <img src="~/images/logo.png" alt="Logo" class="img-fluid" style="max-height: 320px;" />
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var game in Model.Games)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow" style="background-color: #2a2a2a; color: #f0f0f0;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold" style="color: #ff8c00;">@game.Name</h5>
                    <p class="card-text" style="color: #aaa;">@game.Description</p>
                    <div class="mt-auto">
                        <a href="#" class="btn w-100" style="background-color: #ff8c00; color: #1a1a1a; font-weight: bold;">Spil nu</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
