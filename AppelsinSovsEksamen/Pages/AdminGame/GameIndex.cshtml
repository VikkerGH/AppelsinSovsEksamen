@page
@model AppelsinSovsEksamen.Pages.AdminGame.GameIndexModel
@{
    ViewData["Title"] = "Admin - Spiloversigt";
}

<div class="container mt-4" style="color: #f0f0f0;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Administrer spil</h2>
        <a asp-page="./GameCreate" class="btn" style="background-color: #ff8c00; color: #1a1a1a; font-weight: bold;">Opret nyt spil</a>
    </div>

    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Navn</th>
                <th>Beskrivelse</th>
                <th>Handlinger</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var game in Model.Games)
            {
                <tr>
                    <td>@game.Name</td>
                    <td>@game.Description</td>
                    <td>
                        <a asp-page="./GameEdit" asp-route-id="@game.Id" class="btn btn-sm btn-outline-warning">Rediger</a>
                        <a asp-page="./GameDelete" asp-route-id="@game.Id" class="btn btn-sm btn-outline-danger">Slet</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>